# Copy this file to ".env" and fill in your real keys.
# The .env file is git-ignored and is NEVER committed or sent to the browser.

# Claude (Anthropic) — used when Provider = Claude
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Gemma (OpenRouter) — used when Provider = Gemma  (optional)
GEMMA_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
